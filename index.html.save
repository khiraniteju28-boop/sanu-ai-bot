            <img src="https://images.unsplash.com/photo-1610030469983-98e550d6193c?w=200">
            <p>Silk Saree</p>
            <p style="color:#f43397; font-weight:bold;">₹499</p>
            <button class="buy-btn" onclick="document.getElementById('modal').style.display='block'">Buy Now</button>
        </div>
    </div>
    <div id="modal">
        <div class="m-content">
            <h3>Scan QR & Pay</h3>
            <img src="qr-code.png" style="width:200px; border:1px solid #eee;">
            <p>Screenshot WhatsApp Karein!</p>
            <a href="https://wa.me/91XXXXXXXXXX" style="background:#25D366; color:white; padding:12px; text-decoration:none; display:block; border-radius:5px; font-weight:bold;">WhatsApp Bheinjein</a>
            <br>
            <button onclick="document.getElementById('modal').style.display='none'">Back</button>
        </div>
    </div>
</body>
</html>
